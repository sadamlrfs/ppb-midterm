rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: only the owner can read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Theses: only the student who owns it can CRUD
    match /theses/{thesisId} {
      allow read, write: if request.auth != null &&
        (resource == null || resource.data.studentId == request.auth.uid);
    }

    // Milestones, sessions, notes, attachments:
    // any authenticated user can read/write (scoped by thesisId in app logic)
    match /milestones/{id} {
      allow read, write: if request.auth != null;
    }

    match /sessions/{id} {
      allow read, write: if request.auth != null;
    }

    match /notes/{id} {
      allow read, write: if request.auth != null;
    }

    match /attachments/{id} {
      allow read, write: if request.auth != null;
    }

    match /media/{id} {
      allow read, write: if request.auth != null;
    }

    match /bimbingan/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
